        <script><![CDATA[(function executeRule(current, previous) {

    var tableName = current.table_name;
    var recordSysId = current.table_sys_id;

    // Only run for your table
    if (tableName != 'x_1909471_inspec_0_device') {
        return;
    }

    gs.info("Sync images for record " + recordSysId);

    var baseUrl = gs.getProperty('glide.servlet.uri');

    var html = '';

    // Get ALL remaining attachments for this record
    var att = new GlideRecord('sys_attachment');
    att.addQuery('table_name', tableName);
    att.addQuery('table_sys_id', recordSysId);
    att.orderBy('sys_created_on');
    att.query();

    while (att.next()) {

        // only images
        if (!att.content_type || att.content_type.indexOf('image/') != 0) {
            continue;
        }

        html += '<img src="' + baseUrl +
            'sys_attachment.do?sys_id=' + att.sys_id +
            '" style="width:300px;height:auto;margin:10px;" />\n';
    }

    // Update parent record
    var rec = new GlideRecord(tableName);
    if (rec.get(recordSysId)) {

        rec.setWorkflow(false);
        rec.u_image_html = html;
        rec.update();
    }

})(current, previous);]]></script>
